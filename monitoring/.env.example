# Monitoring Stack Environment Variables

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_this_secure_password_in_production
GF_SERVER_ROOT_URL=http://localhost:3000
GF_SERVER_HTTP_PORT=3000

# Grafana Database (SQLite by default, can use PostgreSQL/MySQL)
# GF_DATABASE_TYPE=sqlite3
# GF_DATABASE_PATH=/var/lib/grafana/grafana.db

# Grafana SMTP Configuration (for alerting)
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.gmail.com:587
# GF_SMTP_USER=your-email@gmail.com
# GF_SMTP_PASSWORD=your-app-password
# GF_SMTP_FROM_ADDRESS=grafana@yourdomain.com
# GF_SMTP_FROM_NAME=Grafana

# Grafana OAuth (Google example)
# GF_AUTH_GOOGLE_ENABLED=true
# GF_AUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GF_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# GF_AUTH_GOOGLE_ALLOWED_DOMAINS=yourdomain.com
# GF_AUTH_GOOGLE_ALLOW_SIGN_UP=true

# Prometheus Configuration
PROMETHEUS_RETENTION=30d
PROMETHEUS_STORAGE_TSDB_PATH=/prometheus

# Backend API Configuration (for Prometheus scraping)
BACKEND_API_URL=http://host.docker.internal:3001
BACKEND_METRICS_PATH=/metrics
BACKEND_METRICS_USER=admin
BACKEND_METRICS_PASSWORD=secure_password

# Network Configuration
MONITORING_NETWORK=monitoring-network

# Volume Configuration
GRAFANA_DATA_VOLUME=./grafana/data
PROMETHEUS_DATA_VOLUME=./prometheus/data
