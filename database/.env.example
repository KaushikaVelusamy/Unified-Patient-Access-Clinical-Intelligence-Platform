# ============================================================================
# Database Configuration Template
# Clinical Appointment Platform (UPACI)
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update values with your actual configuration
# 3. NEVER commit .env to version control
# ============================================================================

# ============================================================================
# PostgreSQL Connection Settings
# ============================================================================

# Database host (localhost for local, IP/domain for remote)
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# Database name (created by init script)
DB_NAME=upaci

# Database user (default: postgres, create app-specific user for production)
DB_USER=postgres

# Database password (CHANGE THIS FOR PRODUCTION!)
DB_PASSWORD=postgres

# Enable SSL connection (false for development, true for production)
DB_SSL=false

# SSL certificate paths (required if DB_SSL=true)
# DB_SSL_CA=/path/to/ca-certificate.crt
# DB_SSL_CERT=/path/to/client-certificate.crt
# DB_SSL_KEY=/path/to/client-key.key

# ============================================================================
# Connection Pool Settings
# ============================================================================

# Minimum number of connections in pool
DB_POOL_MIN=2

# Maximum number of connections in pool
DB_POOL_MAX=10

# Connection timeout in milliseconds
DB_CONNECT_TIMEOUT=30000

# Idle timeout in milliseconds (disconnect idle connections after)
DB_IDLE_TIMEOUT=10000

# Maximum lifetime of connection in milliseconds  
DB_MAX_LIFETIME=1800000

# Connection retry attempts on failure
DB_RETRY_ATTEMPTS=3

# Delay between retry attempts in milliseconds
DB_RETRY_DELAY=1000

# ============================================================================
# Schema and Search Path
# ============================================================================

# Default schema for application tables
DB_SCHEMA=app

# Additional schemas to include in search path (comma-separated)
DB_SEARCH_PATH=app,ai,public

# ============================================================================
# AI Features Configuration
# ============================================================================

# Enable pgvector extension and vector search
ENABLE_PGVECTOR=true

# Enable all AI-powered features (semantic search, clustering, recommendations)
ENABLE_AI_FEATURES=true

# Fallback to PostgreSQL full-text search if pgvector unavailable
FALLBACK_TO_FULLTEXT=true

# ============================================================================
# Query and Performance Settings
# ============================================================================

# Enable query logging for debugging (false for production)
DB_LOG_QUERIES=false

# Slow query threshold in milliseconds (log queries slower than this)
DB_SLOW_QUERY_THRESHOLD=1000

# Enable statement timeout (0 = disabled, time in milliseconds)
DB_STATEMENT_TIMEOUT=30000

# Enable connection pooling monitoring
DB_POOL_MONITORING=true

# ============================================================================
# Backup and Maintenance
# ============================================================================

# Backup directory path
DB_BACKUP_DIR=./backups

# Auto-vacuum settings (managed by PostgreSQL, configure in postgresql.conf)
# These are reference values for manual configuration
# DB_AUTOVACUUM=on
# DB_AUTOVACUUM_NAPTIME=1min

# ============================================================================
# Development and Testing
# ============================================================================

# Database URL (alternative to individual settings)
# Format: postgresql://[user[:password]@][host][:port][/dbname][?param=value]
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/upaci

# Enable database seeding for development
DB_SEED_DATA=false

# Drop and recreate database on server restart (DANGEROUS - dev only!)
DB_DROP_ON_RESTART=false

# Run migrations automatically on startup
DB_RUN_MIGRATIONS=true

# ============================================================================
# Production Security Settings
# ============================================================================

# Encrypt connections in transit
DB_FORCE_SSL=false

# Reject unauthorized SSL certificates
DB_SSL_REJECT_UNAUTHORIZED=false

# Database connection string for read replicas (optional)
# DB_READ_REPLICA_URL=postgresql://postgres:password@replica-host:5432/upaci

# Enable connection pooler (PgBouncer, PgPool) 
# DB_USE_POOLER=false
# DB_POOLER_URL=postgresql://postgres:password@pooler-host:6432/upaci

# ============================================================================
# Monitoring and Logging
# ============================================================================

# Enable performance monitoring
DB_ENABLE_MONITORING=true

# Log connection events
DB_LOG_CONNECTIONS=false

# Log disconnection events
DB_LOG_DISCONNECTIONS=false

# Log query execution plans
DB_LOG_QUERY_PLANS=false

# ============================================================================
# Notes and Best Practices
# ============================================================================
# 
# PRODUCTION CHECKLIST:
# [ ] Change DB_PASSWORD to strong password (32+ characters)
# [ ] Create dedicated application user (not postgres superuser)
# [ ] Enable SSL (DB_SSL=true) with valid certificates
# [ ] Set DB_POOL_MAX based on expected load
# [ ] Enable query logging initially, disable after stabilization
# [ ] Configure regular backups
# [ ] Set up monitoring and alerting
# [ ] Use read replicas for high-traffic scenarios
# [ ] Implement connection pooling (PgBouncer recommended)
#
# SECURITY:
# - Never commit .env file to version control
# - Use environment-specific configuration management
# - Rotate database passwords regularly
# - Implement least-privilege access control
# - Audit database access logs
# 
# PERFORMANCE:
# - Start with DB_POOL_MAX=10, adjust based on metrics
# - Enable connection pooling for >100 concurrent users
# - Use read replicas for read-heavy workloads
# - Monitor slow queries and create indexes as needed
#
# AI FEATURES:
# - Requires pgvector extension installed
# - Fallback to full-text search if ENABLE_PGVECTOR=false
# - See docs/FALLBACK_STRATEGY.md for details
#
# ============================================================================
