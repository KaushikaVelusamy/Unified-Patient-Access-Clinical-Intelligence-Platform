# Required Environment Variables
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=upaci
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_URL=postgresql://postgres:your_password_here@localhost:5432/upaci
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis Configuration (Upstash Redis with TLS)
# Get credentials from: https://console.upstash.com/redis
REDIS_URL=rediss://your-upstash-endpoint.upstash.io:6379
REDIS_TOKEN=your-upstash-token-here
REDIS_TLS=true
REDIS_MAX_RETRIES=3

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI Configuration (for AI features - US_041)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Email Configuration (for notifications - US_016)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@clinic.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@clinic.com

# Twilio Configuration (for SMS reminders - US_016)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Prometheus Metrics Configuration (for monitoring - US_005)
# Enable/disable metrics collection
METRICS_ENABLED=true
# Enable basic authentication for /metrics endpoint (recommended for production)
METRICS_AUTH_ENABLED=true
# Basic auth credentials (change in production)
METRICS_AUTH_USER=admin
METRICS_AUTH_PASS=change-this-secure-password-in-production
# IP whitelist for metrics endpoint (comma-separated, defaults to localhost)
# Example: 127.0.0.1,::1,10.0.0.5,192.168.1.100
METRICS_IP_WHITELIST=127.0.0.1,::1

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
